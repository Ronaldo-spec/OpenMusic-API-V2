{
  "name": "openmusic-api-v2",
  "version": "1.0.0",
  "description": "RESTful music catalog and playlist API built with Hapi.js, PostgreSQL, and JWT authentication.",
  "main": "index.js",
  "scripts": {
    "start:prod": "NODE_ENV=production node ./src/server.js",
    "start:dev": "nodemon ./src/server.js",
    "lint": "eslint ./src",
    "migrate": "node-pg-migrate"
  },
  "keywords": [
    "nodejs",
    "hapi",
    "postgresql",
    "jwt",
    "rest-api"
  ],
  "author": "Ronaldo Firmansyah",
  "license": "ISC",
  "devDependencies": {
    "eslint": "^8.52.0",
    "nodemon": "^3.0.3"
  },
  "dependencies": {
    "@hapi/hapi": "^21.3.2",
    "@hapi/jwt": "^3.2.0",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.1",
    "joi": "^17.12.0",
    "nanoid": "^3.1.22",
    "node-pg-migrate": "^6.2.2",
    "pg": "^8.11.3"
  }
}
